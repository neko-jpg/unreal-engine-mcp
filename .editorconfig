# EditorConfig: cross-editor consistency
# http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{h,cpp,cs}]
indent_style = tab
indent_size = 4

[*.{ps1,bat}]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.rs]
indent_size = 4

[*.toml]
indent_size = 4

[*.py]
indent_size = 4
indent_style = space

[*.{sh,bash,zsh}]
indent_size = 2
indent_style = space

[*.{js,ts,jsx,tsx}]
indent_size = 2
indent_style = space
