# direnv 設定: cd したら自動で Python 仮想環境を有効化
# インストール: https://direnv.net/
# セットアップ: direnv allow

# Python 仮想環境を自動アクティベート
source_env_if_exists() {
    if [ -f "$1" ]; then
        source "$1"
    fi
}

# uv が生成する .venv
source_env_if_exists ".venv/bin/activate"
source_env_if_exists ".venv/Scripts/activate"

# Python 側の .venv
source_env_if_exists "Python/.venv/bin/activate"
source_env_if_exists "Python/.venv/Scripts/activate"

# 環境変数のデフォルト値（上書き可能）
: ${UNREAL_MCP_HOST:="127.0.0.1"}
: ${UNREAL_MCP_PORT:="55557"}

export UNREAL_MCP_HOST
export UNREAL_MCP_PORT
