{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "unreal-engine-mcp": {
      "type": "local",
      "command": [
        "Python/.venv/Scripts/python.exe",
        "Python/unreal_mcp_server_advanced.py"
      ],
      "environment": {
        "UNREAL_MCP_HOST": "127.0.0.1",
        "UNREAL_MCP_PORT": "55557"
      },
      "enabled": true
    }
  }
}
