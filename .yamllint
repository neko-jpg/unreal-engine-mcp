# yamllint 設定: YAML ファイルの静的解析
# インストール: pip install yamllint
# 実行: yamllint -c .yamllint .

extends: default

rules:
  line-length:
    max: 120
    level: warning
    allow-non-breakable-inline-mappings: true
  indentation:
    spaces: 2
    indent-sequences: consistent
  document-start:
    present: false
  truthy:
    check-keys: false  # GitHub Actions uses truthy values
  comments:
    min-spaces-from-content: 1